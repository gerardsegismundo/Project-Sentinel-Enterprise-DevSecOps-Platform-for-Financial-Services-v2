{
  "dashboard": {
    "title": "Security Overview — Project Sentinel",
    "tags": ["security", "compliance", "pci-dss"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": { "from": "now-24h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Falco Alerts (Last 24h)",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(increase(falco_events_total[24h])) or vector(0)",
            "legendFormat": "Total Alerts"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 10 }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Kyverno Policy Violations",
        "type": "stat",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(kyverno_policy_results_total{rule_result=\"fail\"}) or vector(0)",
            "legendFormat": "Violations"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "red", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Failed Authentication Attempts",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(increase(http_requests_total{namespace=\"banking\",status=\"401\"}[24h])) or vector(0)",
            "legendFormat": "401 Unauthorized"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 100 }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Rate Limited Requests (429)",
        "type": "stat",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(increase(http_requests_total{namespace=\"banking\",status=\"429\"}[24h])) or vector(0)",
            "legendFormat": "Rate Limited"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 50 },
                { "color": "red", "value": 500 }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Falco Alerts by Severity",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(falco_events_total{priority=\"Critical\"}[5m])) or vector(0)",
            "legendFormat": "Critical"
          },
          {
            "expr": "sum(rate(falco_events_total{priority=\"Warning\"}[5m])) or vector(0)",
            "legendFormat": "Warning"
          },
          {
            "expr": "sum(rate(falco_events_total{priority=\"Notice\"}[5m])) or vector(0)",
            "legendFormat": "Notice"
          }
        ]
      },
      {
        "id": 6,
        "title": "NetworkPolicy Denied Connections",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(hubble_drop_total{namespace=\"banking\"}[5m])) by (reason) or vector(0)",
            "legendFormat": "{{ reason }}"
          }
        ]
      },
      {
        "id": 7,
        "title": "Pod Security Standard Violations",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(pod_security_evaluations_total{decision=\"deny\",mode=\"enforce\"}[5m])) by (namespace) or vector(0)",
            "legendFormat": "{{ namespace }}"
          }
        ]
      },
      {
        "id": 8,
        "title": "Container Image Vulnerabilities (Last Scan)",
        "type": "table",
        "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "trivy_image_vulnerabilities{namespace=\"banking\"} or vector(0)",
            "format": "table",
            "legendFormat": "{{ severity }}"
          }
        ]
      },
      {
        "id": 9,
        "title": "Suspicious Outbound Connections",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 18, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"banking\"}[5m])) by (pod)",
            "legendFormat": "{{ pod }} — egress bytes/s"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "Bps" }
        }
      },
      {
        "id": 10,
        "title": "RBAC — Active Service Accounts",
        "type": "stat",
        "gridPos": { "x": 12, "y": 18, "w": 6, "h": 6 },
        "targets": [
          {
            "expr": "count(kube_serviceaccount_info{namespace=\"banking\"}) or vector(0)",
            "legendFormat": "Service Accounts"
          }
        ]
      },
      {
        "id": 11,
        "title": "Secrets Sync Status (External Secrets)",
        "type": "stat",
        "gridPos": { "x": 18, "y": 18, "w": 6, "h": 6 },
        "targets": [
          {
            "expr": "sum(externalsecret_status_condition{condition=\"Ready\",status=\"True\"}) or vector(0)",
            "legendFormat": "Synced"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "green", "value": 1 }
              ]
            }
          }
        }
      }
    ]
  }
}
